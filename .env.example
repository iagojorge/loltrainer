# Chave da Riot Games API — obtenha em https://developer.riotgames.com/
# Chaves de desenvolvimento ("RGAPI-...") expiram a cada 24h.
RIOT_API_KEY=

# Plataforma padrão usada como fallback quando o roteamento não puder ser
# derivado do prefixo do Match ID (ex.: br1, na1, euw1, kr).
RIOT_PLATFORM=br1

# Segredo para assinar os tokens de sessão (JWT). Use uma string longa e aleatória.
# Gere uma: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# ---- Banco ----
# LOCAL (desenvolvimento): deixe TURSO_DATABASE_URL vazio → usa SQLite em arquivo
# (server/src/data/lol.db) via node:sqlite. Nada a configurar.
#
# PRODUÇÃO (Vercel): defina as duas variáveis abaixo com os dados do seu banco
# Turso (https://turso.tech). Quando TURSO_DATABASE_URL está definido, o app usa
# libSQL/Turso automaticamente.
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Porta da API (só no local; no Vercel é ignorada).
PORT=3001
